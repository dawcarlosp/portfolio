---
export interface Props {
  title: string;
  description: string;
  tags: { label: string; color: string }[];
  links: { label: string; url: string }[];
  image?: string;
  imageAlt?: string;
  featured?: boolean;
  accent?: 'aurora' | 'violet' | 'blue';
  badge?: string;
}

const { title, description, tags, links, image, imageAlt, featured = false, accent = 'aurora', badge } = Astro.props;

const accentMap = {
  aurora: {
    border: 'border-aurora/20',
    hoverBorder: 'hover:border-aurora/40',
    shadow: 'rgba(0,255,204,0.12)',
    text: 'text-aurora',
    bg: 'bg-aurora/10',
    gradient: 'from-aurora/5 via-transparent to-transparent',
  },
  violet: {
    border: 'border-violet/20',
    hoverBorder: 'hover:border-violet/40',
    shadow: 'rgba(155,81,224,0.12)',
    text: 'text-violet',
    bg: 'bg-violet/10',
    gradient: 'from-violet/5 via-transparent to-transparent',
  },
  blue: {
    border: 'border-blue-accent/20',
    hoverBorder: 'hover:border-blue-accent/40',
    shadow: 'rgba(59,130,246,0.12)',
    text: 'text-blue-accent',
    bg: 'bg-blue-accent/10',
    gradient: 'from-blue-accent/5 via-transparent to-transparent',
  },
};

const a = accentMap[accent];
const wrapperClass = featured
  ? 'md:col-span-2 md:grid md:grid-cols-2 md:gap-8'
  : '';
---

<div class={`glass rounded-2xl overflow-hidden transition-all duration-500 hover:scale-[1.02] hover:shadow-[0_0_35px_${a.shadow}] ${a.hoverBorder} border ${a.border} group ${wrapperClass}`}>
  {
    image && (
      <div class="relative aspect-video bg-gradient-to-br ${a.gradient} overflow-hidden">
        <img
          src={image}
          alt={imageAlt ?? title}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
        />
        {
          badge && (
            <span class="absolute top-3 left-3 px-3 py-1 rounded-full text-xs font-medium glass border border-white/10 text-aurora">
              {badge}
            </span>
          )
        }
      </div>
    )
  }

  <div class="p-6 md:p-8 flex flex-col justify-between">
    <div>
      {
        featured && (
          <span class={`inline-block px-3 py-1 rounded-full text-xs font-medium ${a.bg} ${a.text} mb-3`}>
            Proyecto destacado
          </span>
        )
      }
      <h3 class="text-xl md:text-2xl font-heading font-bold text-white mb-3">
        {title}
      </h3>
      <p class="text-text-muted text-sm leading-relaxed mb-5">
        {description}
      </p>
      <div class="flex flex-wrap gap-2 mb-6">
        {
          tags.map((tag) => (
            <span
              class={`px-2.5 py-1 rounded-md text-xs font-medium ${tag.color}`}
            >
              {tag.label}
            </span>
          ))
        }
      </div>
    </div>
    <div class="flex flex-wrap gap-3">
      {
        links.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium transition-all duration-300 ${
              link.label === 'Código'
                ? 'glass border border-white/10 text-text-muted hover:bg-white/5 hover:text-text-primary'
                : `${a.bg} ${a.text} hover:bg-${a.bg}/20`
            }`}
          >
            {link.label}
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        ))
      }
    </div>
  </div>
</div>

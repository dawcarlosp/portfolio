---
import SectionHeading from './SectionHeading.astro';

interface Skill {
  name: string;
  icon?: string;
}

interface Category {
  id: string;
  title: string;
  level: 'core' | 'competent' | 'exploration' | 'infra';
  items: Skill[];
}

const categories: Category[] = [
  {
    id: 'core',
    title: 'Núcleo',
    level: 'core',
    items: [
      { name: 'Java', icon: 'https://skillicons.dev/icons?i=java' },
      { name: 'Spring Boot', icon: 'https://skillicons.dev/icons?i=spring' },
      { name: 'React', icon: 'https://skillicons.dev/icons?i=react' },
      { name: 'TypeScript', icon: 'https://skillicons.dev/icons?i=ts' },
      { name: 'Vite', icon: 'https://skillicons.dev/icons?i=vite' },
      { name: 'MySQL', icon: 'https://skillicons.dev/icons?i=mysql' },
      { name: 'Tailwind', icon: 'https://skillicons.dev/icons?i=tailwind' },
      { name: 'HTML5', icon: 'https://skillicons.dev/icons?i=html' },
    ],
  },
  {
    id: 'competent',
    title: 'Competente',
    level: 'competent',
    items: [
      { name: 'Angular', icon: 'https://skillicons.dev/icons?i=angular' },
      { name: 'ASP.NET Core', icon: 'https://skillicons.dev/icons?i=dotnet' },
      { name: 'C#', icon: 'https://skillicons.dev/icons?i=cs' },
      { name: 'SQL Server', icon: 'https://skillicons.dev/icons?i=mysql' },
      { name: 'JavaScript', icon: 'https://skillicons.dev/icons?i=js' },
      { name: 'Bootstrap', icon: 'https://skillicons.dev/icons?i=bootstrap' },
    ],
  },
  {
    id: 'exploration',
    title: 'Exploración',
    level: 'exploration',
    items: [
      { name: 'Node.js', icon: 'https://skillicons.dev/icons?i=nodejs' },
      { name: 'Laravel', icon: 'https://skillicons.dev/icons?i=laravel' },
      { name: 'PHP', icon: 'https://skillicons.dev/icons?i=php' },
      { name: 'React Native', icon: 'https://skillicons.dev/icons?i=react' },
      { name: 'MongoDB', icon: 'https://skillicons.dev/icons?i=mongodb' },
      { name: 'CSS3', icon: 'https://raw.githubusercontent.com/dawcarlosp/dawcarlosp/main/assets-perfil/css_new_logo.png' },
    ],
  },
  {
    id: 'infra',
    title: 'Infraestructura',
    level: 'infra',
    items: [
      { name: 'Docker', icon: 'https://skillicons.dev/icons?i=docker' },
      { name: 'GCP', icon: 'https://skillicons.dev/icons?i=gcp' },
      { name: 'Linux', icon: 'https://raw.githubusercontent.com/devicons/devicon/master/icons/linux/linux-original.svg' },
      { name: 'Git', icon: 'https://skillicons.dev/icons?i=git' },
      { name: 'Postman', icon: 'https://skillicons.dev/icons?i=postman' },
    ],
  },
];

const levelConfig = {
  core: {
    dotColor: 'bg-green-400',
    dotGlow: 'shadow-[0_0_8px_rgba(74,222,128,0.5)]',
    borderColor: 'border-green-500/20',
    barColor: 'bg-gradient-to-r from-green-400 to-emerald-500',
    label: 'Proyectos reales',
  },
  competent: {
    dotColor: 'bg-yellow-400',
    dotGlow: 'shadow-[0_0_8px_rgba(250,204,21,0.5)]',
    borderColor: 'border-yellow-500/20',
    barColor: 'bg-gradient-to-r from-yellow-400 to-amber-500',
    label: 'Proyectos académicos',
  },
  exploration: {
    dotColor: 'bg-blue-400',
    dotGlow: 'shadow-[0_0_8px_rgba(96,165,250,0.5)]',
    borderColor: 'border-blue-500/20',
    barColor: 'bg-gradient-to-r from-blue-400 to-indigo-500',
    label: 'Probadas conceptualmente',
  },
  infra: {
    dotColor: 'bg-purple-400',
    dotGlow: 'shadow-[0_0_8px_rgba(192,132,252,0.5)]',
    borderColor: 'border-purple-500/20',
    barColor: 'bg-gradient-to-r from-purple-400 to-violet-500',
    label: 'Uso puntual',
  },
};
---

<section id="skills" class="relative py-24 px-4">
  <div class="max-w-5xl mx-auto">
    <SectionHeading
      title="Stack tecnológico"
      subtitle="Organizado por nivel de dominio, sin inflar ni minimizar."
    />

    <div class="space-y-10">
      {
        categories.map((category, catIdx) => {
          const cfg = levelConfig[category.level];
          return (
            <div class={`stagger-${catIdx + 1} animate-fade-in-up`}>
              <div class="flex items-center gap-3 mb-5">
                <div class={`w-3 h-3 rounded-full ${cfg.dotColor} ${cfg.dotGlow}`} />
                <h3 class="text-lg font-heading font-semibold text-white">
                  {category.title}
                </h3>
                <span class="text-xs text-text-muted/60 font-light">{cfg.label}</span>
                <div class="flex-1 h-px bg-gradient-to-r from-white/10 to-transparent ml-2" />
              </div>

              <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-3">
                {
                  category.items.map((skill) => (
                    <div
                      class={`group glass rounded-xl p-3 flex flex-col items-center justify-center gap-2 transition-all duration-300 hover:scale-105 border ${cfg.borderColor} cursor-default`}
                    >
                      {
                        skill.icon ? (
                          <div class="w-10 h-10 flex items-center justify-center">
                            <img
                              src={skill.icon}
                              alt={skill.name}
                              class="w-8 h-8 object-contain transition-transform duration-300 group-hover:scale-110"
                              loading="lazy"
                            />
                          </div>
                        ) : (
                          <div class="w-10 h-10 flex items-center justify-center">
                            <span class="text-lg font-heading font-bold text-aurora/60">{skill.name.charAt(0)}</span>
                          </div>
                        )
                      }
                      <span class="text-[11px] text-text-muted group-hover:text-text-primary transition-colors duration-300 font-medium text-center leading-tight">
                        {skill.name}
                      </span>
                    </div>
                  ))
                }
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

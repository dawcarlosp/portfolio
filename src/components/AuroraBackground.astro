<svg class="fixed inset-0 w-full h-full pointer-events-none" viewBox="0 0 1200 800" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="z-index: -1; opacity: 0.6;">
  <defs>
    <radialGradient id="auroraGradient" cx="50%" cy="0%" r="90%">
      <stop offset="0%" stop-color="#00ffcc" stop-opacity="0.3" />
      <stop offset="100%" stop-color="#00ffcc" stop-opacity="0" />
    </radialGradient>
    <radialGradient id="auroraHalo" cx="50%" cy="0%" r="120%">
      <stop offset="0%" stop-color="#00ffee" stop-opacity="0.15" />
      <stop offset="100%" stop-color="#00ffee" stop-opacity="0" />
    </radialGradient>
    <radialGradient id="deepViolet" cx="50%" cy="40%" r="80%">
      <stop offset="0%" stop-color="#9B51E0" stop-opacity="0.7" />
      <stop offset="100%" stop-color="#6A3093" stop-opacity="0.1" />
    </radialGradient>
    <radialGradient id="deepBlue" cx="50%" cy="50%" r="80%">
      <stop offset="0%" stop-color="#3B82F6" stop-opacity="0.6" />
      <stop offset="100%" stop-color="#1e3a8a" stop-opacity="0.2" />
    </radialGradient>
    <filter id="blurAurora"><feGaussianBlur stdDeviation="18" /></filter>
    <filter id="blurHalo"><feGaussianBlur stdDeviation="50" /></filter>
    <filter id="softDepth">
      <feGaussianBlur in="SourceGraphic" stdDeviation="6" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <linearGradient id="trailGradient" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="white" stop-opacity="0.8" />
      <stop offset="100%" stop-color="white" stop-opacity="0" />
    </linearGradient>
  </defs>

  <rect width="100%" height="100%" fill="#0B132B" />

  <g filter="url(#blurHalo)">
    <path fill="url(#auroraHalo)" opacity="0.5">
      <animateTransform attributeName="transform" type="translate" values="0 0; 80 0; -80 0; 0 0" dur="14s" repeatCount="indefinite" />
      <animate attributeName="d" dur="14s" repeatCount="indefinite"
        values="M0,0 Q300,140 600,60 T1200,100 L1200,800 L0,800 Z;M0,0 Q300,180 600,80 T1200,70 L1200,800 L0,800 Z;M0,0 Q300,100 600,110 T1200,140 L1200,800 L0,800 Z;M0,0 Q300,140 600,60 T1200,100 L1200,800 L0,800 Z" />
    </path>
  </g>

  <g filter="url(#blurAurora)">
    <path fill="url(#auroraGradient)" opacity="0.3">
      <animateTransform attributeName="transform" type="translate" values="0 0; 80 0; -80 0; 0 0" dur="10s" repeatCount="indefinite" />
      <animate attributeName="d" dur="10s" repeatCount="indefinite"
        values="M0,0 Q300,90 600,60 T1200,90 L1200,800 L0,800 Z;M0,0 Q300,140 600,40 T1200,120 L1200,800 L0,800 Z;M0,0 Q300,70 600,90 T1200,60 L1200,800 L0,800 Z;M0,0 Q300,90 600,60 T1200,90 L1200,800 L0,800 Z" />
    </path>
  </g>

  <path fill="url(#deepViolet)" filter="url(#softDepth)" d="M0,420 C300,340 900,480 1200,400 L1200,800 L0,800 Z">
    <animate attributeName="d" dur="9s" repeatCount="indefinite"
      values="M0,420 C300,340 900,480 1200,400 L1200,800 L0,800 Z;M0,400 C350,440 850,370 1200,420 L1200,800 L0,800 Z;M0,420 C300,340 900,480 1200,400 L1200,800 L0,800 Z" />
  </path>
  <path fill="url(#deepBlue)" filter="url(#softDepth)" d="M0,460 C400,380 800,510 1200,430 L1200,800 L0,800 Z">
    <animate attributeName="d" dur="8s" repeatCount="indefinite"
      values="M0,460 C400,380 800,510 1200,430 L1200,800 L0,800 Z;M0,440 C450,460 750,410 1200,450 L1200,800 L0,800 Z;M0,460 C400,380 800,510 1200,430 L1200,800 L0,800 Z" />
  </path>
  <path fill="url(#deepViolet)" filter="url(#softDepth)" d="M0,500 C500,410 700,540 1200,460 L1200,800 L0,800 Z">
    <animate attributeName="d" dur="7s" repeatCount="indefinite"
      values="M0,500 C500,410 700,540 1200,460 L1200,800 L0,800 Z;M0,480 C520,480 680,490 1200,470 L1200,800 L0,800 Z;M0,500 C500,410 700,540 1200,460 L1200,800 L0,800 Z" />
  </path>
  <path fill="url(#deepBlue)" filter="url(#softDepth)" d="M0,540 C500,450 700,570 1200,490 L1200,800 L0,800 Z">
    <animate attributeName="d" dur="6.5s" repeatCount="indefinite"
      values="M0,540 C500,450 700,570 1200,490 L1200,800 L0,800 Z;M0,520 C520,500 680,530 1200,510 L1200,800 L0,800 Z;M0,540 C500,450 700,570 1200,490 L1200,800 L0,800 Z" />
  </path>
</svg>

<section id="stats" class="relative py-24 px-4">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-heading font-bold text-center mb-4 stagger-1 animate-fade-in-up">
      <span class="text-gradient">Estad&iacute;sticas de GitHub</span>
    </h2>
    <p class="text-text-muted text-center mb-16 max-w-xl mx-auto stagger-2 animate-fade-in-up">
      Mi actividad y lenguajes m&aacute;s utilizados en GitHub.
    </p>

    <div id="github-stats" class="space-y-8">
      <div class="grid md:grid-cols-2 gap-8 stagger-3 animate-fade-in-up">
        <div class="glass rounded-2xl p-6">
          <h3 class="text-lg font-heading font-semibold text-aurora mb-5 text-center">Lenguajes m&aacute;s usados</h3>
          <div id="langs-content" class="flex flex-col items-center justify-center min-h-[200px]">
            <div class="w-8 h-8 border-2 border-aurora/30 border-t-aurora rounded-full animate-spin"></div>
            <p class="text-text-muted text-sm mt-3">Cargando lenguajes...</p>
          </div>
        </div>

        <div class="glass rounded-2xl p-6">
          <h3 class="text-lg font-heading font-semibold text-violet mb-5 text-center">Estad&iacute;sticas generales</h3>
          <div id="general-content" class="flex flex-col items-center justify-center min-h-[200px]">
            <div class="w-8 h-8 border-2 border-violet/30 border-t-violet rounded-full animate-spin"></div>
            <p class="text-text-muted text-sm mt-3">Cargando estad&iacute;sticas...</p>
          </div>
        </div>
      </div>

      <div class="glass rounded-2xl p-6 stagger-4 animate-fade-in-up">
        <h3 class="text-lg font-heading font-semibold text-blue-accent mb-5 text-center">Actividad reciente</h3>
        <div id="activity-content" class="flex flex-col items-center justify-center min-h-[200px]">
          <div class="w-8 h-8 border-2 border-blue-accent/30 border-t-blue-accent rounded-full animate-spin"></div>
          <p class="text-text-muted text-sm mt-3">Cargando actividad...</p>
        </div>
      </div>
    </div>

    <div id="github-stats-error" class="hidden text-center stagger-3 animate-fade-in-up">
      <div class="glass rounded-2xl p-8 max-w-lg mx-auto">
        <p class="text-text-muted mb-2">No se pudieron cargar las estad&iacute;sticas de GitHub.</p>
        <p class="text-text-muted/60 text-sm">Puedes ver mi perfil directamente en GitHub.</p>
        <a href="https://github.com/dawcarlosp" target="_blank" rel="noopener noreferrer"
          class="inline-block mt-4 px-4 py-2 rounded-full glass border border-white/10 text-aurora hover:bg-aurora/10 transition-all text-sm">
          Ir a GitHub
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const USERNAME = 'dawcarlosp';
  const COLORS = [
    '#00ffcc', '#3B82F6', '#9B51E0', '#f59e0b',
    '#ef4444', '#10b981', '#f97316', '#ec4899',
    '#14b8a6', '#8b5cf6',
  ];

  function getLanguageColor(lang: string): string {
    const map: Record<string, string> = {
      JavaScript: '#f7df1e',
      TypeScript: '#3178c6',
      Java: '#b07219',
      'C#': '#178600',
      PHP: '#4F5D95',
      Python: '#3572A5',
      HTML: '#e34c26',
      CSS: '#563d7c',
      Shell: '#89e051',
      Dockerfile: '#384d54',
    };
    return map[lang] || '#6366f1';
  }

  async function fetchWithTimeout(url: string, ms: number = 8000): Promise<Response> {
    const controller = new AbortController();
    const id = setTimeout(() => controller.abort(), ms);
    try {
      const res = await fetch(url, { signal: controller.signal });
      return res;
    } finally {
      clearTimeout(id);
    }
  }

  async function loadLanguages() {
    const container = document.getElementById('langs-content');
    if (!container) return;
    try {
      const repos = await (await fetchWithTimeout(
        `https://api.github.com/users/${USERNAME}/repos?per_page=100&sort=updated`
      )).json();

      if (!Array.isArray(repos)) throw new Error('Invalid response');

      const langPromises = repos
        .filter((r) => !r.fork)
        .map((r) =>
          fetchWithTimeout(r.languages_url).then((res) => (res.ok ? res.json() : {}))
        );

      const langResults = await Promise.all(langPromises);
      const totals: Record<string, number> = {};
      langResults.forEach((langs) => {
        Object.entries(langs).forEach(([lang, bytes]) => {
          totals[lang] = (totals[lang] || 0) + bytes;
        });
      });

      const sorted = Object.entries(totals)
        .sort(([, a], [, b]) => b - a)
        .slice(0, 8);

      const totalBytes = sorted.reduce((acc, [, v]) => acc + v, 0);

      if (sorted.length === 0) throw new Error('No language data');

      container.innerHTML = `
        <div class="w-full max-w-md space-y-3">
          ${sorted
            .map(
              ([lang, bytes], i) => `
            <div class="flex items-center gap-3">
              <span class="w-2 h-2 rounded-full shrink-0" style="background: ${getLanguageColor(lang)}"></span>
              <span class="text-sm text-text-primary w-24 font-medium">${lang}</span>
              <div class="flex-1 h-2 rounded-full bg-white/5 overflow-hidden">
                <div class="h-full rounded-full transition-all duration-1000" style="width: ${((bytes / totalBytes) * 100).toFixed(1)}%; background: ${getLanguageColor(lang)}"></div>
              </div>
              <span class="text-xs text-text-muted w-16 text-right">${((bytes / totalBytes) * 100).toFixed(1)}%</span>
            </div>
          `
            )
            .join('')}
        </div>
      `;
    } catch {
      container.innerHTML = `
        <p class="text-text-muted text-sm">No se pudieron cargar los lenguajes.</p>
      `;
    }
  }

  async function loadGeneral() {
    const container = document.getElementById('general-content');
    if (!container) return;
    try {
      const user = await (await fetchWithTimeout(
        `https://api.github.com/users/${USERNAME}`
      )).json();

      if (!user.login) throw new Error('Invalid response');

      container.innerHTML = `
        <div class="grid grid-cols-2 gap-4 w-full max-w-sm">
          <div class="glass rounded-xl p-4 text-center">
            <p class="text-2xl font-heading font-bold text-aurora">${user.public_repos}</p>
            <p class="text-xs text-text-muted mt-1">Repositorios</p>
          </div>
          <div class="glass rounded-xl p-4 text-center">
            <p class="text-2xl font-heading font-bold text-violet">${user.followers}</p>
            <p class="text-xs text-text-muted mt-1">Seguidores</p>
          </div>
          <div class="glass rounded-xl p-4 text-center">
            <p class="text-2xl font-heading font-bold text-blue-accent">${user.public_gists}</p>
            <p class="text-xs text-text-muted mt-1">Gists</p>
          </div>
          <div class="glass rounded-xl p-4 text-center">
            <p class="text-2xl font-heading font-bold text-amber-400">${user.following}</p>
            <p class="text-xs text-text-muted mt-1">Siguiendo</p>
          </div>
        </div>
      `;
    } catch {
      container.innerHTML = `
        <p class="text-text-muted text-sm">No se pudieron cargar las estad&iacute;sticas.</p>
      `;
    }
  }

  interface GitHubEvent {
    type: string;
    repo: { name: string };
    created_at: string;
  }

  async function loadActivity() {
    const container = document.getElementById('activity-content');
    if (!container) return;
    try {
      const events = await (await fetchWithTimeout(
        `https://api.github.com/users/${USERNAME}/events/public?per_page=5`
      )).json() as GitHubEvent[];

      if (!Array.isArray(events)) throw new Error('Invalid response');

      const typeIcons: Record<string, string> = {
        PushEvent: '↑',
        CreateEvent: '+',
        IssuesEvent: '●',
        IssueCommentEvent: '💬',
        PullRequestEvent: '⇄',
        WatchEvent: '☆',
        ForkEvent: '⑂',
        DeleteEvent: '✕',
      };

      container.innerHTML = `
        <div class="w-full max-w-2xl mx-auto space-y-3">
          ${events
            .slice(0, 5)
            .map(
              (event) => `
            <div class="flex items-start gap-3 glass rounded-xl px-4 py-3">
              <span class="text-lg shrink-0 mt-0.5">${typeIcons[event.type] || '⚡'}</span>
              <div class="flex-1 min-w-0">
                <p class="text-sm text-text-primary truncate">${event.repo.name}</p>
                <p class="text-xs text-text-muted">${new Date(event.created_at).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}</p>
              </div>
            </div>
          `
            )
            .join('')}
        </div>
      `;
    } catch {
      container.innerHTML = `
        <div class="text-center">
          <p class="text-text-muted text-sm">No se pudo cargar la actividad reciente.</p>
          <a href="https://github.com/${USERNAME}" target="_blank" rel="noopener noreferrer"
            class="inline-block mt-3 text-xs text-aurora hover:underline">Ver perfil</a>
        </div>
      `;
    }
  }

  async function loadAll() {
    try {
      await Promise.all([loadLanguages(), loadGeneral(), loadActivity()]);
    } catch {
      const statsEl = document.getElementById('github-stats');
      const errorEl = document.getElementById('github-stats-error');
      if (statsEl) statsEl.classList.add('hidden');
      if (errorEl) errorEl.classList.remove('hidden');
    }
  }

  document.addEventListener('DOMContentLoaded', loadAll);
</script>
